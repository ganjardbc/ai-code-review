# Server
PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# Redis (required)
REDIS_URL=redis://localhost:6379

# AI Runner: "direct" (9Router API) or "opencode" (local CLI). Default: direct
AI_RUNNER=direct

# 9Router AI Gateway (required when AI_RUNNER=direct)
NINE_ROUTER_API_KEY=your-9router-api-key-here
NINE_ROUTER_BASE_URL=https://api.9router.com/v1
NINE_ROUTER_MODEL=opencode

# opencode CLI (required when AI_RUNNER=opencode)
# OPENCODE_COMMAND=opencode
# OPENCODE_TIMEOUT_MS=120000

# GitHub Integration (required)
GITHUB_WEBHOOK_SECRET=your-github-webhook-secret
GITHUB_ACCESS_TOKEN=your-github-personal-access-token

# GitLab Integration (required)
GITLAB_WEBHOOK_SECRET=your-gitlab-webhook-secret
GITLAB_ACCESS_TOKEN=your-gitlab-personal-access-token
GITLAB_API_URL=https://gitlab.example.com

# Feature flags. Accepted values: true | false | 1 | 0
# ENABLE_REVIEW_BY_COMMENT — triggers from /review comments (GitHub issue_comment + GitLab Note Hook). Default: true
# ENABLE_REVIEW_BY_MR_OPEN — triggers from PR/MR open/reopen/sync (GitHub pull_request + GitLab Merge Request Hook). Default: true
# ENABLE_FIX_BY_COMMENT — triggers from /fix comments: fetches outstanding AI review comments, applies fixes, commits and pushes to the PR/MR branch. Default: false
ENABLE_REVIEW_BY_COMMENT=true
ENABLE_REVIEW_BY_MR_OPEN=true
ENABLE_FIX_BY_COMMENT=false

# Worker
WORKSPACE_DIR=/tmp/ai-reviewer/workspace
QUEUE_JOB_TTL_SECONDS=86400
QUEUE_MAX_JOBS_RETAINED=100

# Telegram notifications (optional — both required together or neither)
# TELEGRAM_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11
# TELEGRAM_CHAT_ID=your-chat-id
