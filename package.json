{
  "name": "ai-code-reviewer",
  "version": "0.1.0",
  "description": "Self-hosted AI Code Reviewer integrating with GitHub and GitLab",
  "main": "dist/presentation/web/server.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/presentation/web/server.ts",
    "dev:worker": "tsx src/worker.ts",
    "start": "node dist/presentation/web/server.js",
    "start:worker": "node dist/worker.js",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "keywords": [],
  "license": "MIT",
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^26.0.1",
    "@types/supertest": "^7.2.0",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^10.5.0",
    "pino-pretty": "^13.1.3",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "@fastify/helmet": "^13.0.2",
    "@gitbeaker/rest": "^43.8.0",
    "@octokit/rest": "19",
    "ajv": "^8.20.0",
    "axios": "^1.18.1",
    "bullmq": "^5.79.1",
    "dotenv": "^17.4.2",
    "fastify": "^5.8.5",
    "fs-extra": "^11.3.5",
    "ioredis": "^5.11.1",
    "pino": "^10.3.1",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  }
}
